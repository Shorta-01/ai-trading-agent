POSTGRES_DB=ai_trading_agent
POSTGRES_USER=ai_trading_agent
POSTGRES_PASSWORD=replace-with-local-password-do-not-commit
API_PORT=8000
WEB_PORT=3000
ENVIRONMENT=development
PAPER_ONLY_MODE=true

# --- V1 release readiness (Task 177 / Slice 22) ---
# See `docs/deployment.md` for the runbook. Poll `GET /v1/release-readiness`
# to check whether every required flag is set before firing the morning chain.

# Opslag (verplicht voor V1)
STORAGE_ENABLED=true
# STORAGE_DATABASE_URL=postgresql+psycopg://ai_trading_agent:replace-with-local-password-do-not-commit@localhost:5432/ai_trading_agent
STORAGE_WRITES_ENABLED=true

# EODHD (market-data + fundamentals)
EODHD_ENABLED=true
# EODHD_API_KEY=replace-with-real-key

# IBKR paper-account (TWS Gateway via host/port/client_id)
IBKR_ENABLED=true
IBKR_SYNC_ENABLED=true
IBKR_SYNC_ACCOUNT_MODE=paper
# IBKR_SYNC_HOST=127.0.0.1
# IBKR_SYNC_PORT=4002
# IBKR_SYNC_CLIENT_ID=42

# APScheduler (06:30 morning chain)
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Europe/Brussels
SCHEDULER_DAILY_BRIEFING_CRON=30 6 * * *

# Morning-chain legs (all six required for end-to-end V1)
MARKET_DATA_SYNC_ENABLED=true
FORECAST_SYNC_ENABLED=true
SUGGESTIONS_SYNC_ENABLED=true
DECISION_PACKAGES_SYNC_ENABLED=true
ACTION_DRAFTS_SYNC_ENABLED=true
DAILY_BRIEFING_SYNC_ENABLED=true

# Audit-pad (reconciliation + Prediction Diary)
RECONCILIATION_SYNC_ENABLED=true
PREDICTION_DIARY_SYNC_ENABLED=true

# --- V1.1 settings (Task 178 / Slice 23 lock — wired by Slices 24+) ---
# §22.2 monthly budget cap for real Anthropic Claude calls. The budget is
# enforced at the call boundary by Slice 29 (real explanation provider) and
# Slice 30 (real TS predictor); declared here so the env-var surface is
# documented from Slice 23 onward.
CLAUDE_AI_BUDGET_MONTHLY_EUR=50
# Slice 29 — real Anthropic Claude explanation provider. Key has no
# committed default; provide via env. Default model is Claude Haiku 4.5
# (cheapest tier). Output cap keeps the per-call cost predictable.
# CLAUDE_AI_API_KEY=replace-with-real-key
CLAUDE_AI_EXPLANATION_MODEL=claude-haiku-4-5-20251001
CLAUDE_AI_EXPLANATION_MAX_OUTPUT_CHARS=2000
# §22.4 operator-selectable universe set. Wired by Slice 31. Default
# `SP500` keeps the V1 behaviour. Allowed values: SP500 | EU600 | ALL_5K.
UNIVERSE_SET=SP500
# Slice 24 + 25 backtesting opt-in. Default False keeps the morning chain
# running on the V1 predictors until Slice 26 wires the auto-weight loop.
PREDICTOR_BACKTEST_ENABLED=false

# --- Backups (docs/deployment.md mandates encrypted, restore-tested backups) ---
# Off-Pi destination — mount an external disk / NFS share here. Keep it off
# the boot media so a Pi/SD/NVMe failure cannot take the backups with it.
BACKUP_DIR=/mnt/backups/ai-trading-agent
BACKUP_RETENTION_DAYS=14
# Path to a file holding the GPG symmetric passphrase (chmod 600, never
# committed). backup-postgres.sh AES256-encrypts every dump and refuses to
# run without it; restore-test.sh needs the same passphrase to verify.
BACKUP_GPG_PASSPHRASE_FILE=/run/secrets/backup_passphrase