POSTGRES_DB=ai_trading_agent
POSTGRES_USER=ai_trading_agent
POSTGRES_PASSWORD=replace-with-local-password-do-not-commit
API_PORT=8000
WEB_PORT=3000
ENVIRONMENT=development
PAPER_ONLY_MODE=true

# --- V1 release readiness (Task 177 / Slice 22) ---
# See `docs/deployment.md` for the runbook. Poll `GET /v1/release-readiness`
# to check whether every required flag is set before firing the morning chain.

# Opslag (verplicht voor V1)
STORAGE_ENABLED=true
# STORAGE_DATABASE_URL=postgresql+psycopg://ai_trading_agent:replace-with-local-password-do-not-commit@localhost:5432/ai_trading_agent
STORAGE_WRITES_ENABLED=true

# EODHD (market-data + fundamentals)
EODHD_ENABLED=true
# EODHD_API_KEY=replace-with-real-key

# IBKR paper-account (TWS Gateway via host/port/client_id)
IBKR_ENABLED=true
IBKR_SYNC_ENABLED=true
IBKR_SYNC_ACCOUNT_MODE=paper
# IBKR_SYNC_HOST=127.0.0.1
# IBKR_SYNC_PORT=4002
# IBKR_SYNC_CLIENT_ID=42

# APScheduler (06:30 morning chain)
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Europe/Brussels
SCHEDULER_DAILY_BRIEFING_CRON=30 6 * * *

# Morning-chain legs (all six required for end-to-end V1)
MARKET_DATA_SYNC_ENABLED=true
FORECAST_SYNC_ENABLED=true
SUGGESTIONS_SYNC_ENABLED=true
DECISION_PACKAGES_SYNC_ENABLED=true
ACTION_DRAFTS_SYNC_ENABLED=true
DAILY_BRIEFING_SYNC_ENABLED=true

# Audit-pad (reconciliation + Prediction Diary)
RECONCILIATION_SYNC_ENABLED=true
PREDICTION_DIARY_SYNC_ENABLED=true